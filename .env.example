# Smoker Pods — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA commite o .env.local no Git.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Número do WhatsApp para receber pedidos (DDI+DDD, sem espaços ou hífen)
NEXT_PUBLIC_WHATSAPP_NUMBER=559991036173

# ATENÇÃO: a service_role key NUNCA deve ir para o frontend.
# Se precisar de operações privilegiadas, use Route Handlers (app/api/*)
# com SUPABASE_SERVICE_ROLE_KEY apenas no servidor.
